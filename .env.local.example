# TMDb API Key
# 1. Sign up at https://www.themoviedb.org/signup
# 2. Go to https://www.themoviedb.org/settings/api
# 3. Request an API key (choose "Developer")
# 4. Copy this file to .env.local and paste your key below
TMDB_API_KEY=your_api_key_here

# OMDb API Key (optional — enables IMDb/RT/Metacritic ratings on show pages)
# Get a free key at https://www.omdbapi.com/apikey.aspx (1000 req/day)
# OMDB_API_KEY=your_omdb_key_here

# Trakt API Client ID (optional — improves recommendations with Trakt related shows)
# Create an app at https://trakt.tv/oauth/applications and use the Client ID
# TRAKT_CLIENT_ID=your_trakt_client_id_here

# Upstash Redis (auto-populated by Vercel when you add the integration)
# For local dev, these are optional — falls back to data/shows.json
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
